#!/usr/bin/env bash

# Database Connection
DATABASE_URL="postgresql://devuser:devpass@127.0.0.1:5432/devdb?sslmode=disable"

# Admin User Configuration (Created on first startup)
ADMIN_PASSWORD="your_secure_admin_password"
ADMIN_EMAIL="admin@example.com"
ADMIN_USER="System Admin"

# LDAP Configuration (Optional)
LDAP_BASE_DN="dc=example,dc=com"
LDAP_USER_FILTER="(&(objectClass=user)(sAMAccountName=%s))"
LDAP_BIND_DN="cn=admin,dc=example,dc=com"
LDAP_BIND_PASSWORD="your_ldap_password"
LDAP_ADMIN_GROUP_DN="cn=admin,dc=example,dc=com"

# OpenID Connect (OIDC) Configuration (Optional)
OIDC_ISSUER="https://your-oidc-auth-provider.com"
OIDC_CLIENT_ID="your-oidc-client-id"
OIDC_CLIENT_SECRET="your-oidc-client-secret"
OIDC_REDIRECT_URL="http://localhost:3000/api/auth/oidc/callback"

# Application Settings
FRONTEND_URL="http://localhost:5173"

# Telemetry Configuration (Optional)
# OTEL_TRACES_EXPORTER=stdout
# OTEL_METRICS_EXPORTER=stdout

# Security Settings
ENABLE_CSRF=false
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
CORS_ALLOWED_ORIGINS=http://localhost:5173
